APP_ENV=local
APP_NAME=internal-assistant-mvp

# Local database
DATABASE_URL=postgresql+psycopg://assistant:assistant@localhost:5432/assistant

# Local/runtime LLM configuration
LLM_PROVIDER=auto
LLM_BASE_URL=
LLM_API_KEY=
EMBEDDINGS_PROVIDER=auto
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=512

# Local service-to-service settings
ADMIN_API_KEY=change-this-admin-key
APP_SHARED_SECRET=change-this-shared-secret
APPLICATIONINSIGHTS_CONNECTION_STRING=
ALLOWED_ORIGINS=
BOT_ENDPOINT=
CUSTOM_INCIDENTS_API_BASE_URL=http://localhost:7071
INDEXER_API_BASE_URL=http://localhost:7072
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=
TEAMS_APP_ID=
LOG_LEVEL=INFO
RETRIEVAL_CONFIDENCE_THRESHOLD=0.58

# Local evaluation
EVAL_USE_LLM_JUDGE=false
EVAL_DATASET_PATH=evaluation/datasets/rag_eval_questions.json
EVAL_OUTPUT_DIR=evaluation/reports
EVAL_TOP_K=5
EVAL_VECTOR_WEIGHT=0.70
EVAL_TEXT_WEIGHT=0.30
EVAL_PROVIDER=mock
